local TAB_NAMES = {"main","prediction","techs","custom anims","misc","ui settings"}
local panes,btns={},{}
local activeName=nil

for i,name in ipairs(TAB_NAMES) do
    -- button
    local btn=n("TextButton",{Size=UDim2.new(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,
        BackgroundTransparency=1,Text=name,TextColor3=C.t3,FontFace=MONO,TextSize=11,
        LayoutOrder=i,Parent=TB})
    pad(btn,0,16,2,16)
    local ul=n("Frame",{Name="ul",Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=C.t1,BorderSizePixel=0,BackgroundTransparency=1,Parent=btn})
    btns[name]=btn
    -- pane
    local pane=n("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,Visible=false,LayoutOrder=i,Parent=Content})
    vlist(pane,4)
    panes[name]=pane
    btn.MouseButton1Click:Connect(function()
        if activeName==name then return end
        activeName=name
        for _,nm in ipairs(TAB_NAMES) do
            panes[nm].Visible=(nm==name)
            btns[nm].TextColor3=(nm==name) and C.t1 or C.t3
            local u=btns[nm]:FindFirstChild("ul")
            if u then u.BackgroundTransparency=(nm==name) and 0 or 1 end
        end
    end)
end

local function showTab(name)
    activeName=name
    for _,nm in ipairs(TAB_NAMES) do
        panes[nm].Visible=(nm==name)
        btns[nm].TextColor3=(nm==name) and C.t1 or C.t3
        local u=btns[nm]:FindFirstChild("ul")
        if u then u.BackgroundTransparency=(nm==name) and 0 or 1 end
    end
end

