-- ── Tab system ────────────────────────────────────────────────
local tabDefs = {"main","prediction","techs","custom anims","misc","ui settings"}
local tabPanes = {}
local tabBtns  = {}
local activeTab = nil

local BodyLayout = newInst("UIListLayout", {
    SortOrder = Enum.SortOrder.LayoutOrder,
    Padding = UDim.new(0,0),
    Parent = Body,
})

local function switchTab(name)
    if activeTab == name then return end
    activeTab = name
    for _, t in pairs(tabDefs) do
        if tabPanes[t] then tabPanes[t].Visible = (t == name) end
        if tabBtns[t] then
            local active = (t == name)
            tabBtns[t].TextColor3 = active and C.t1 or C.t3
            -- underline via child frame
            local ul = tabBtns[t]:FindFirstChild("Underline")
            if ul then ul.BackgroundTransparency = active and 0 or 1 end
        end
    end
end

for i, tname in ipairs(tabDefs) do
    -- button
    local btn = newInst("TextButton", {
        Size = UDim2.new(0, 0, 1, -2),
        AutomaticSize = Enum.AutomaticSize.X,
        BackgroundTransparency = 1,
        Text = tname,
        TextColor3 = C.t3,
        FontFace = FONT_MONO,
        TextSize = 11,
        LayoutOrder = i,
        Parent = TabBar,
