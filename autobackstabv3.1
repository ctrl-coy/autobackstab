-- button
local function button(parent,label,order,cb)
    local btn=n("TextButton",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.sur2,
        BorderSizePixel=0,Text=label,TextColor3=C.t2,FontFace=MONO,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=order or 0,Parent=parent})
    corner(btn); stroke(btn); pad(btn,0,0,0,11)
    btn.MouseEnter:Connect(function() btn.TextColor3=C.t1; btn.BackgroundColor3=Color3.fromHex("1e1e1e") end)
    btn.MouseLeave:Connect(function() btn.TextColor3=C.t2; btn.BackgroundColor3=C.sur2 end)
    btn.MouseButton1Click:Connect(function() if cb then cb() end end)
    return btn
end

-- divider
local function divider(parent,order)
    n("Frame",{Size=UDim2.new(1,0,0,1),BackgroundColor3=C.bdr,
        BorderSizePixel=0,LayoutOrder=order or 0,Parent=parent})
end

-- two-column wrapper → returns left col, right col
local function cols(parent,order)
    local wrap=n("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,LayoutOrder=order or 0,Parent=parent})
    n("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,
        VerticalAlignment=Enum.VerticalAlignment.Top,
        Padding=UDim.new(0,10),SortOrder=Enum.SortOrder.LayoutOrder,Parent=wrap})
    local function col(lo)
        local c=n("Frame",{Size=UDim2.new(0.5,-5,0,0),AutomaticSize=Enum.AutomaticSize.Y,
            BackgroundTransparency=1,LayoutOrder=lo,Parent=wrap})
        vlist(c,4)
        return c
    end
    return col(0),col(1)
end

