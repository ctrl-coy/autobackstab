-- killer tracker
RunService.Heartbeat:Connect(function()
    local kf = getKillersFolder(); if not kf then return end
    local now = os.clock()
    for _,killer in pairs(kf:GetChildren()) do
        local khrp = killer:FindFirstChild("HumanoidRootPart")
        if khrp then
            local s = killerTrack[khrp]
            local pos,look = khrp.Position, khrp.CFrame.LookVector
            if s and s.t and s.pos then
                local dt = now - s.t
                if dt > 0 then
                    local vel = (pos - s.pos)/dt
                    local sv  = s.vel and s.vel:Lerp(vel, math.clamp(dt*10,0,1)) or vel
                    killerTrack[khrp] = {pos=pos,look=look,vel=sv,t=now,prevLook=s.look}
                else
                    killerTrack[khrp] = {pos=pos,look=look,vel=Vector3.zero,t=now,prevLook=s and s.look or look}
                end
            else
                killerTrack[khrp] = {pos=pos,look=look,vel=Vector3.zero,t=now,prevLook=look}
            end
        end
    end
end)

local function activateForKiller(killerModel, duration)
    if not killerModel then return end
    local ch  = getCharacter()
    local hum = ch and ch:FindFirstChildWhichIsA("Humanoid")
    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    local khrp= killerModel:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp or not khrp then return end
    local didAim = false
    if aimingEnabled then
        aimRefCount += 1; didAim = true
        if aimRefCount==1 then pcall(function() hum.AutoRotate=false end) end
    end
    local function finish()
        if didAim then
            aimRefCount = math.max(0,aimRefCount-1)
            if aimRefCount==0 then setAutoRotate(true) end
        end
    end
    if not aimingEnabled then task.delay(duration or DEFAULT_DURATION, finish); return end
    local function cframe()
        local kc = khrp.CFrame
        local bp = kc.Position - kc.LookVector.Unit*BEHIND_DISTANCE
        bp = Vector3.new(bp.X, kc.Position.Y, bp.Z)
        if not predictionEnabled or (BACKSTAB_TYPE~="lerp" and BACKSTAB_TYPE~="teleport") then
            return CFrame.new(bp, bp+kc.LookVector.Unit)
        end
        local tr = killerTrack[khrp]
        local vel= tr and tr.vel or Vector3.zero
        pcall(function() if not tr then vel = khrp.Velocity or Vector3.zero end end)
        local hv = Vector3.new(vel.X,0,vel.Z)
        local pm = hv*(PREDICTION_TIME or 0.12)*(PREDICTION_STRENGTH or 0.6)
        local fw,ri = kc.LookVector, kc.RightVector
        local off = fw*(pm:Dot(fw)) + ri*(pm:Dot(ri))
        if tr and tr.prevLook then
            local ta = (fw-tr.prevLook):Dot(ri)
            off = off + ri*(ta*3*(PREDICTION_STRENGTH or 0.6))
        end
        local fp = bp + Vector3.new(off.X,0,off.Z)
        return CFrame.new(fp, fp+kc.LookVector.Unit)
    end
    if hrp.Anchored then hrp.Anchored=false end
    if BACKSTAB_TYPE=="lerp" then
        local tw = pcall(function()
            TweenService:Create(hrp,TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{CFrame=cframe()}):Play()
        end)
        local t0=os.clock(); local conn
        conn = RunService.Heartbeat:Connect(function()
            if os.clock()-t0>=(duration or DEFAULT_DURATION) then conn:Disconnect();conn=nil;finish();return end
            if khrp and hrp then hrp.CFrame=hrp.CFrame:Lerp(cframe(),LERP_SPEED) end
        end)
    elseif BACKSTAB_TYPE=="teleport" then
        pcall(function() hrp.CFrame=cframe() end)
        local t0=os.clock(); local conn
        conn = RunService.Heartbeat:Connect(function()
            if os.clock()-t0>=(duration or DEFAULT_DURATION) then conn:Disconnect();conn=nil;finish();return end
            pcall(function() if khrp and hrp then hrp.CFrame=cframe() end end)
        end)
    else
        local t0=os.clock(); local conn
        conn = RunService.Heartbeat:Connect(function()
            if os.clock()-t0>=(duration or DEFAULT_DURATION) then conn:Disconnect();conn=nil;finish();return end
            if khrp and hrp then
                local lv=khrp.CFrame.LookVector; local cp=hrp.Position
                pcall(function() hrp.CFrame=CFrame.new(cp,cp+lv) end)
            end
        end)
    end
end

local function isPlayingTargetAnim(ch)
    if not ch then return false end
    local h=ch:FindFirstChildWhichIsA("Humanoid"); if not h then return false end
    local ok,tr=pcall(function() return h:GetPlayingAnimationTracks() end)
    if not ok or not tr then return false end
    for _,t in ipairs(tr) do
        local a=t.Animation
        if a and a.AnimationId then
            local d=tostring(a.AnimationId):match("%d+")
            if d and d==tostring(TARGET_ANIM_ID) then return true end
        end
    end
    return false
end

local function isBesideKiller(hrp,khrp,range)
    if not hrp or not khrp then return false end
    local rel=hrp.Position-khrp.Position
    if Vector3.new(rel.X,0,rel.Z).Magnitude>range then return false end
    if rel.Magnitude<=0 then return false end
    return math.abs(rel.Unit:Dot(khrp.CFrame.RightVector))>=0.9
end

local function findCandidateKillerForAssist(kf,hrp,range)
    if not kf or not hrp then return nil end
    local near,nd=nil,math.huge
    for _,k in pairs(kf:GetChildren()) do
        if isValidKillerModel(k) then
            local khrp=k:FindFirstChild("HumanoidRootPart")
            if khrp then
                local d=(khrp.Position-hrp.Position).Magnitude
                if d<=(range or math.huge) then
                    if isBesideKiller(hrp,khrp,range or math.huge) then return k end
                    if d<nd then near=k;nd=d end
                end
            end
        end
    end
    return near
end

local function doGlidestabAssist(killerModel)
    if not killerModel then return end
    local ch  = getCharacter()
    local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
    local hum = ch and ch:FindFirstChildWhichIsA("Humanoid")
    local khrp= killerModel:FindFirstChild("HumanoidRootPart")
    if not hrp or not hum or not khrp then return end
    local useMode = typeof(aimingMode)=="string" and aimingMode or "Character"
    local cam=workspace.CurrentCamera
    local prevCam = useMode=="Camera" and cam and cam.CFrame or nil
    local didAim=false
    if aimingEnabled and useMode=="Character" then
        aimRefCount+=1; didAim=true
        if aimRefCount==1 then pcall(function() hum.AutoRotate=false end) end
    end
    local function restore()
        if didAim then aimRefCount=math.max(0,aimRefCount-1); if aimRefCount==0 then setAutoRotate(true) end end
        if prevCam and workspace.CurrentCamera then pcall(function() workspace.CurrentCamera.CFrame=prevCam end) end
    end
    if isBesideKiller(hrp,khrp,DEFAULT_PROXIMITY) then restore(); return end
    local t0=os.clock()
    while os.clock()-t0 < (GLIDESTAB_ASSIST_DURATION or 0.5) do
        if not hrp or not khrp then break end
        if isBesideKiller(hrp,khrp,DEFAULT_PROXIMITY) then restore(); return end
        local rel=hrp.Position-khrp.Position
        local ss=(rel:Dot(khrp.CFrame.RightVector)>=0) and 1 or -1
        local pp=khrp.Position
        if predictionEnabled then
            local tr=killerTrack[khrp]
            if tr and tr.vel then
                local hv=Vector3.new(tr.vel.X,0,tr.vel.Z)
                pp=pp+hv*(PREDICTION_TIME or 0.12)*(PREDICTION_STRENGTH or 0.6)
            end
        end
        local sp=pp+(khrp.CFrame.RightVector*ss*6)
        if useMode=="Character" then
            pcall(function()
                local cf=CFrame.new(hrp.Position,sp)
                hrp.CFrame=CFrame.new(cf.Position,cf.Position+cf.LookVector)
            end)
        elseif cam then
            pcall(function() cam.CFrame=CFrame.new(cam.CFrame.Position,sp) end)
        end
        task.wait(GLIDESTAB_ASSIST_CHECK_RATE or 0.03)
    end
    restore()
end

local function isPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    if not model:FindFirstChildWhichIsA("Humanoid") then return false end
    return Players:GetPlayerFromCharacter(model)~=nil
end

