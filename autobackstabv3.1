    newInst("UIPadding", {
        PaddingLeft = UDim.new(0,16), PaddingRight = UDim.new(0,16),
        Parent = btn,
    })
    local ul = newInst("Frame", {
        Name = "Underline",
        Size = UDim2.new(1,0,0,2),
        Position = UDim2.new(0,0,1,-2),
        BackgroundColor3 = C.t1,
        BorderSizePixel = 0,
        BackgroundTransparency = 1,
        Parent = btn,
    })
    tabBtns[tname] = btn

    -- pane
