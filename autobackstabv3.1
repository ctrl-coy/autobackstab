        BackgroundTransparency = 1,
        Visible = false,
        LayoutOrder = i,
        Parent = Body,
    })
    newInst("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,4), Parent = pane })
    tabPanes[tname] = pane

    btn.MouseButton1Click:Connect(function() switchTab(tname) end)
end

