-- WATCHERS (original logic, unchanged)
-- ══════════════════════════════════════════════════════════════════════

task.spawn(function()
    while true do
        task.wait(CHECK_INTERVAL)
        if not enabled then continue end
        local range=DEFAULT_PROXIMITY
        local daggerbtn=getDaggerButton()
        local kf=getKillersFolder(); if not kf then continue end
        local ch=getCharacter(); local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        for _,killer in pairs(kf:GetChildren()) do
            if isValidKillerModel(killer) then
                local khrp=killer:FindFirstChild("HumanoidRootPart")
                if khrp then
                    local dist=(khrp.Position-hrp.Position).Magnitude
                    local trig=false
                    if rangeMode=="Around" then
                        if dist<=range then trig=true end
                    else
                        local rel=hrp.Position-khrp.Position
                        local fd=rel:Dot(khrp.CFrame.LookVector)
                        local bd=-fd; local ad=0
                        if rel.Magnitude>0 then ad=(rel.Unit):Dot(khrp.CFrame.LookVector) end
                        local pass=false
                        if directbehind then if ad<=-0.85 then pass=true end
                        else if fd<0.3 then pass=true end end
                        if pass and bd<=range and dist<=range and isPlayerCharacter(killer) then trig=true end
                    end
                    if trig and os.clock()-lastTrigger>=COOLDOWN then
                        lastTrigger=os.clock()
                        local cd=getDaggerCooldown(); local cdn=readCooldownValue(cd)
                        if not (cdn and cdn>0.1) then
                            task.spawn(function()
                                activateForKiller(killer,DEFAULT_DURATION)
                                if daggerenabled then task.wait(DELAY_BEFORE_STAB); tryActivateButton(daggerbtn) end
                            end)
                        end
                        break
                    end
                end
            end
        end
    end
end)

task.spawn(function()
    while true do
        task.wait(GLIDESTAB_CHECK_RATE or 0.06)
        if not glidestabEnabled then continue end
        if os.clock()-glidestabLastTime < (GLIDESTAB_COOLDOWN or 3) then continue end
        local ch=getCharacter()
        local hrp=ch and ch:FindFirstChild("HumanoidRootPart")
        local hum=ch and ch:FindFirstChildWhichIsA("Humanoid")
        if not hrp or not hum then continue end
        if not isPlayingTargetAnim(ch) then continue end
        local kf=getKillersFolder(); if not kf then continue end
        local range=DEFAULT_PROXIMITY
        local cand=nil
        for _,killer in pairs(kf:GetChildren()) do
            if isValidKillerModel(killer) then
                local khrp=killer:FindFirstChild("HumanoidRootPart")
                if khrp and (khrp.Position-hrp.Position).Magnitude<=range then
                    local t0=os.clock(); local found=false
                    while os.clock()-t0<(GLIDESTAB_BESIDE_TIMEOUT or 1) do
                        if isBesideKiller(hrp,khrp,range) then found=true; break end
                        task.wait(0.05)
                    end
                    if found then cand=killer; break end
                end
            end
        end
        if not cand then continue end
        local khrp=cand:FindFirstChild("HumanoidRootPart"); if not khrp then continue end
        local daggerbtn=getDaggerButton()
        local prevAR=nil; pcall(function() prevAR=hum.AutoRotate end)
        local useMode=typeof(aimingMode)=="string" and aimingMode or "Character"
        local cam=workspace.CurrentCamera
        local prevCam=useMode=="Camera" and cam and cam.CFrame or nil
        glidestabLastTime=os.clock()
        local dur=GLIDESTAB_DURATION or 0.4
        if GLIDESTAB_TYPE=="Teleport" then
            local et=os.clock()+dur
            while os.clock()<et do
                if not hrp or not khrp then break end
                local lv=khrp.CFrame.LookVector.Unit
                local bd=tonumber(BEHIND_DISTANCE) or 1.7
                local bp=khrp.Position-lv*bd
                local tp=Vector3.new(bp.X,hrp.Position.Y,bp.Z)
                pcall(function() hrp.CFrame=CFrame.new(tp,tp+lv) end)
                pcall(function() tryActivateButton(daggerbtn) end)
                task.wait(0.03)
            end
        else
            local et=os.clock()+dur
            if useMode=="Character" then pcall(function() hum.AutoRotate=false end) end
            while os.clock()<et do
                if not hrp or not khrp then break end
                if not isBesideKiller(hrp,khrp,range) then break end
                if useMode=="Character" then
                    pcall(function()
                        local cf=CFrame.new(hrp.Position,khrp.Position)
                        hrp.CFrame=CFrame.new(cf.Position,cf.Position+cf.LookVector)
                    end)
                elseif cam then
                    pcall(function() cam.CFrame=CFrame.new(cam.CFrame.Position,khrp.Position) end)
                end
                pcall(function() tryActivateButton(daggerbtn) end)
                task.wait(0.06)
            end
        end
        if useMode=="Character" then
            pcall(function() if hum then hum.AutoRotate=prevAR~=nil and prevAR or true end end)
        elseif prevCam and workspace.CurrentCamera then
            pcall(function() workspace.CurrentCamera.CFrame=prevCam end)
        end
        task.wait(0.03)
    end
end)

task.spawn(function()
    while true do
        task.wait(GLIDESTAB_ASSIST_CHECK_RATE or 0.03)
        if not glidestabAssistEnabled then glidestabAssistPrevPlaying=false; continue end
        local ch=getCharacter()
        local hum=ch and ch:FindFirstChildWhichIsA("Humanoid")
        if not ch or not hum then glidestabAssistPrevPlaying=false; continue end
        local playing=isPlayingTargetAnim(ch)
        if playing and not glidestabAssistPrevPlaying then
            local kf=getKillersFolder()
            if kf then
                local hrp=ch:FindFirstChild("HumanoidRootPart")
                local cand=nil
                local ok,res=pcall(findCandidateKillerForAssist,kf,hrp)
                if ok and res then cand=res
                else
                    ok,res=pcall(findCandidateKillerForAssist,kf,hrp,math.huge)
                    if ok and res then cand=res
                    else
                        for _,k in ipairs(kf:GetChildren()) do
                            if k:IsA("Model") then
                                local khrp=k:FindFirstChild("HumanoidRootPart") or k:FindFirstChild("UpperTorso") or k:FindFirstChild("Torso")
                                local kh=k:FindFirstChildWhichIsA("Humanoid")
                                if khrp and kh and (kh.Health==nil or kh.Health>0) then cand=k; break end
                            end
                        end
                    end
                end
                if cand then task.spawn(function() pcall(function() doGlidestabAssist(cand) end) end) end
            end
        end
        glidestabAssistPrevPlaying=playing
    end
end)
