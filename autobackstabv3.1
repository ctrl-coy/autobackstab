            Size = UDim2.new(1, 0, 0, 14),
            BackgroundTransparency = 1,
            Text = tipText,
            TextColor3 = C.t2,
            FontFace = FONT_MONO,
            TextSize = 10,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
            LayoutOrder = 1,
            Parent = textCol,
        })
    end
    -- toggle switch
    local tog = newInst("Frame", {
        Size = UDim2.new(0, 34, 0, 18),
        BackgroundColor3 = C.sur3,
        BorderSizePixel = 0,
        LayoutOrder = 1,
        Parent = row,
    })
    newInst("UICorner", { CornerRadius = UDim.new(0,9), Parent = tog })
    makeStroke(tog)
    local thumb = newInst("Frame", {
        Size = UDim2.new(0,10,0,10),
        Position = UDim2.new(0,3,0.5,-5),
        BackgroundColor3 = C.t3,
        BorderSizePixel = 0,
        Parent = tog,
    })
    newInst("UICorner", { CornerRadius = UDim.new(0,5), Parent = thumb })

    local value = default or false
    local function applyState()
        if value then
            tog.BackgroundColor3 = Color3.fromHex("1c1c1c")
            makeStroke(tog, Color3.fromHex("888888"))
            local ts = TweenService:Create(thumb, TweenInfo.new(0.16, Enum.EasingStyle.Quad), {
                Position = UDim2.new(0,21,0.5,-5),
                BackgroundColor3 = C.t1,
            })
            ts:Play()
        else
            tog.BackgroundColor3 = C.sur3
            makeStroke(tog, C.bdr)
            local ts = TweenService:Create(thumb, TweenInfo.new(0.16, Enum.EasingStyle.Quad), {
                Position = UDim2.new(0,3,0.5,-5),
                BackgroundColor3 = C.t3,
            })
            ts:Play()
        end
    end
    applyState()

    local btn = newInst("TextButton", {
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1,
        Text = "",
        Parent = row,
        ZIndex = 5,
    })
    btn.MouseButton1Click:Connect(function()
        value = not value
        applyState()
        if callback then callback(value) end
    end)

    return row, function() return value end, function(v) value = v; applyState() end
end

-- slider
local function makeSlider(parent, labelText, tipText, min, max, step, default, order, callback, fmt)
    local wrap = newInst("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = C.sur2,
        BorderSizePixel = 0,
        LayoutOrder = order or 0,
        Parent = parent,
    })
    newInst("UICorner",  { CornerRadius = UDim.new(0,6), Parent = wrap })
    makeStroke(wrap)
    newInst("UIPadding", {
        PaddingTop = UDim.new(0,9), PaddingBottom = UDim.new(0,11),
        PaddingLeft = UDim.new(0,11), PaddingRight = UDim.new(0,11),
        Parent = wrap,
    })
    local inner = newInst("Frame", {
        Size = UDim2.new(1,0,0,0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Parent = wrap,
    })
    newInst("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Parent = inner })
    -- top row
    local topRow = newInst("Frame", {
        Size = UDim2.new(1,0,0,16),
        BackgroundTransparency = 1,
        LayoutOrder = 0,
        Parent = inner,
    })
    newInst("TextLabel", {
        Size = UDim2.new(0.7,0,1,0),
        BackgroundTransparency = 1,
        Text = labelText,
        TextColor3 = C.t1,
        FontFace = FONT_SEMI,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = topRow,
    })
    local valLabel = newInst("TextLabel", {
        Size = UDim2.new(0.3,0,1,0),
        Position = UDim2.new(0.7,0,0,0),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = C.t2,
        FontFace = FONT_MONO,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Right,
        Parent = topRow,
    })
    -- track
    local trackBg = newInst("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        BackgroundColor3 = C.bdr2,
        BorderSizePixel = 0,
        LayoutOrder = 1,
        Parent = inner,
    })
    newInst("UICorner", { CornerRadius = UDim.new(0,1), Parent = trackBg })
    local fill = newInst("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = C.t1,
        BorderSizePixel = 0,
        Parent = trackBg,
    })
    newInst("UICorner", { CornerRadius = UDim.new(0,1), Parent = fill })
    -- thumb hit area
    local thumbBtn = newInst("TextButton", {
        Size = UDim2.new(1, 0, 0, 18),
        Position = UDim2.new(0, 0, 0.5, -9),
        BackgroundTransparency = 1,
        Text = "",
        Parent = trackBg,
        ZIndex = 4,
    })
    local thumb = newInst("Frame", {
        Size = UDim2.new(0,13,0,13),
        AnchorPoint = Vector2.new(0.5,0.5),
        Position = UDim2.new(0,0,0.5,0),
        BackgroundColor3 = C.t1,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = trackBg,
    })
    newInst("UICorner", { CornerRadius = UDim.new(0,7), Parent = thumb })

    local value = default
    local function setValue(v)
        v = math.clamp(v, min, max)
        if step then v = math.round(v / step) * step end
        value = v
        local t = (v - min) / (max - min)
        fill.Size = UDim2.new(t, 0, 1, 0)
        thumb.Position = UDim2.new(t, 0, 0.5, 0)
        local disp = fmt and fmt(v) or tostring(math.round(v * 100) / 100)
        valLabel.Text = disp
        if callback then callback(v) end
    end
    setValue(default)

    local dragging = false
    thumbBtn.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    game:GetService("UserInputService").InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local abs = trackBg.AbsolutePosition
            local sz  = trackBg.AbsoluteSize
            local t = math.clamp((i.Position.X - abs.X) / sz.X, 0, 1)
            setValue(min + t * (max - min))
        end
    end)
    thumbBtn.MouseButton1Click:Connect(function()
        local abs = trackBg.AbsolutePosition
        local sz  = trackBg.AbsoluteSize
        local mouse = game:GetService("UserInputService"):GetMouseLocation()
        local t = math.clamp((mouse.X - abs.X) / sz.X, 0, 1)
        setValue(min + t * (max - min))
    end)

    return wrap, function() return value end
end

