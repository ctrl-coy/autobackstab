local function getCharacter()
    return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getDaggerButton()
    local pg = LocalPlayer:FindFirstChild("PlayerGui"); if not pg then return nil end
    local mu = pg:FindFirstChild("MainUI"); if not mu then return nil end
    local ac = mu:FindFirstChild("AbilityContainer"); if not ac then return nil end
    return ac:FindFirstChild("Dagger")
end

local function getDaggerCooldown()
    local btn = getDaggerButton(); if not btn then return nil end
    local cd = btn:FindFirstChild("CooldownTime") or btn:FindFirstChild("Cooldown")
            or btn:FindFirstChildWhichIsA("NumberValue") or btn:FindFirstChildWhichIsA("StringValue")
    if cd then return cd end
    return btn:FindFirstChild("CooldownLabel") or btn:FindFirstChild("Timer") or btn:FindFirstChild("CD")
end

local function readCooldownValue(o)
    if not o then return nil end
    if o:IsA("NumberValue") then return o.Value end
    if o:IsA("StringValue") then return tonumber(o.Value) end
    if o:IsA("TextLabel") or o:IsA("TextBox") then return tonumber(o.Text) end
    if o.Value ~= nil then return type(o.Value)=="number" and o.Value or tonumber(o.Value) end
    if o.Text  ~= nil then return tonumber(o.Text) end
end

local function getKillersFolder()
    local pf = Workspace:FindFirstChild("Players"); if not pf then return nil end
    return pf:FindFirstChild("Killers")
end

local function isValidKillerModel(m)
    if not m then return false end
    local h = m:FindFirstChildWhichIsA("Humanoid")
    return m:FindFirstChild("HumanoidRootPart") and h and h.Health and h.Health > 0
end

local function tryActivateButton(btn)
    if not btn then return false end
    pcall(function() if btn.Activate then btn:Activate() end end)
    local ok,conns = pcall(function()
        if type(getconnections)=="function" and btn.MouseButton1Click then
            return getconnections(btn.MouseButton1Click) end end)
    if ok and conns then
        for _,c in ipairs(conns) do
            pcall(function()
                if c.Function then c.Function() elseif c.func then c.func() elseif c.Fire then c.Fire() end
            end)
        end
    end
    pcall(function() if btn.Activated then btn.Activated:Fire() end end)
    return true
end

