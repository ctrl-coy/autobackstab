-- slider
local function slider(parent,label,mn,mx,step,default,order,cb,fmt)
    local f=card(parent,order)
    vlist(f,6)
    local top=n("Frame",{Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,LayoutOrder=0,Parent=f})
    n("TextLabel",{Size=UDim2.new(0.6,0,1,0),BackgroundTransparency=1,Text=label,
        TextColor3=C.t1,FontFace=SEMI,TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,Parent=top})
    local vl=n("TextLabel",{Size=UDim2.new(0.4,0,1,0),Position=UDim2.new(0.6,0,0,0),
        BackgroundTransparency=1,TextColor3=C.t2,FontFace=MONO,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Right,Parent=top})
    local trk=n("Frame",{Size=UDim2.new(1,0,0,2),BackgroundColor3=C.bdr2,
        BorderSizePixel=0,LayoutOrder=1,Parent=f})
    corner(trk,1)
    local fill=n("Frame",{Size=UDim2.new(0,0,1,0),BackgroundColor3=C.t1,BorderSizePixel=0,Parent=trk})
    corner(fill,1)
    local thm=n("Frame",{Size=UDim2.new(0,13,0,13),AnchorPoint=Vector2.new(0.5,0.5),
        BackgroundColor3=C.t1,BorderSizePixel=0,ZIndex=3,Parent=trk})
    corner(thm,7)
    local hitbox=n("TextButton",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0.5,-11),
        BackgroundTransparency=1,Text="",ZIndex=4,Parent=trk})
    local val=default
    local function set(v)
        v=math.clamp(v,mn,mx)
        if step then v=math.round(v/step)*step end
        val=v
        local t=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(t,0,1,0)
        thm.Position=UDim2.new(t,0,0.5,0)
        vl.Text=fmt and fmt(v) or tostring(math.round(v*1000)/1000)
        if cb then cb(v) end
    end
    set(default)
    local drag=false
    hitbox.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end
    end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local abs=trk.AbsolutePosition; local sz=trk.AbsoluteSize
            set(mn+math.clamp((i.Position.X-abs.X)/sz.X,0,1)*(mx-mn))
        end
    end)
    hitbox.MouseButton1Click:Connect(function()
        local abs=trk.AbsolutePosition; local sz=trk.AbsoluteSize
        local m=UIS:GetMouseLocation()
        set(mn+math.clamp((m.X-abs.X)/sz.X,0,1)*(mx-mn))
    end)
    return f
end

-- dropdown
local function dropdown(parent,label,tip,values,default,order,cb)
    local f=card(parent,order)
    n("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,
        VerticalAlignment=Enum.VerticalAlignment.Center,
        Padding=UDim.new(0,8),SortOrder=Enum.SortOrder.LayoutOrder,Parent=f})
    local lft=n("Frame",{Size=UDim2.new(1,-140,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,LayoutOrder=0,Parent=f})
    vlist(lft,2)
    n("TextLabel",{Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,Text=label,
        TextColor3=C.t1,FontFace=SEMI,TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=0,Parent=lft})
    if tip and tip~="" then
        n("TextLabel",{Size=UDim2.new(1,0,0,12),BackgroundTransparency=1,Text=tip,
            TextColor3=C.t2,FontFace=MONO,TextSize=10,TextWrapped=true,
            TextXAlignment=Enum.TextXAlignment.Left,LayoutOrder=1,Parent=lft})
    end
    local cur=default or values[1]
    local vbtn=n("TextButton",{Size=UDim2.new(0,128,0,24),BackgroundColor3=C.sur3,
        BorderSizePixel=0,Text=cur,TextColor3=C.t1,FontFace=MONO,TextSize=11,
        ClipsDescendants=true,ZIndex=5,LayoutOrder=1,Parent=f})
    corner(vbtn,4); stroke(vbtn)
    -- list (absolutely positioned, high ZIndex)
    local list=n("Frame",{
        Size=UDim2.new(0,128,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        AnchorPoint=Vector2.new(0,0),
        BackgroundColor3=C.sur3,BorderSizePixel=0,
        Visible=false,ZIndex=20,Parent=SG, -- parent to ScreenGui to avoid clipping
    })
    corner(list,4); stroke(list,C.bdr2)
    pad(list,4,0,4,0)
    vlist(list,0)
    local function reposition()
        local ap=vbtn.AbsolutePosition; local as=vbtn.AbsoluteSize
        list.Position=UDim2.new(0,ap.X,0,ap.Y+as.Y+4)
    end
    for i,v in ipairs(values) do
        local opt=n("TextButton",{Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,
            Text=v,TextColor3=C.t2,FontFace=MONO,TextSize=11,ZIndex=21,
            LayoutOrder=i,Parent=list})
        opt.MouseEnter:Connect(function() opt.TextColor3=C.t1 end)
        opt.MouseLeave:Connect(function() opt.TextColor3=C.t2 end)
        opt.MouseButton1Click:Connect(function()
            cur=v; vbtn.Text=v; list.Visible=false; if cb then cb(v) end
        end)
    end
    vbtn.MouseButton1Click:Connect(function()
        reposition(); list.Visible=not list.Visible
    end)
    -- close on outside click
    SG.DescendantAdded:Connect(function() end) -- keep ref
    return f
end

