                            pcall(function()
                                mod.Animations = mod.Animations or {}
                                for _, k in ipairs(animKeys) do
                                    local val = TwoTimeAnimInputs[k]
                                    if val and tostring(val) ~= "" then
                                        mod.Animations[k] = tostring(val)
                                    end
                                end
                            end)
                        end
                    end
                    task.wait(1)
                end
            end)
        end
    end)

    makeSec(R, "more things", o())
    makeLabel(R, "when inject anims is on, TwoTime.Config is re-required every ~1s and the ids you filled in are injected. turning it off stops injection.", o())
end

